{
  "name": "skillpulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "ingest": "tsx scripts/run-ingestors.ts",
    "classify": "tsx scripts/run-classifier.ts",
    "build:all": "tsx scripts/build-everything.ts",
    "check-budget": "tsx scripts/check-budget.ts",
    "write-health": "tsx scripts/write-health.ts",
    "digest": "tsx scripts/generate-digest.ts",
    "build:api": "tsx scripts/build-api.ts",
    "build:badges": "tsx scripts/build-badges.ts"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@octokit/rest": "^21.0.0",
    "playwright": "^1.59.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
