---
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';
import Base from '../layouts/Base.astro';

interface Entry {
  kind: string;
  category: string;
  trend: string;
  compat?: string[];
}

const dataPath = join(process.cwd(), '../data/snapshots/latest.json');
const snapshot: { generatedAt: string; totalEntries: number; entries: Entry[] } = existsSync(
  dataPath,
)
  ? JSON.parse(readFileSync(dataPath, 'utf-8'))
  : { generatedAt: new Date().toISOString(), totalEntries: 0, entries: [] };

const entries = snapshot.entries;

const kindCounts = entries.reduce<Record<string, number>>((acc, e) => {
  acc[e.kind] = (acc[e.kind] ?? 0) + 1;
  return acc;
}, {});
const byKind = Object.entries(kindCounts).sort((a, b) => b[1] - a[1]);

const categoryCounts = entries.reduce<Record<string, number>>((acc, e) => {
  acc[e.category] = (acc[e.category] ?? 0) + 1;
  return acc;
}, {});
const byCategory = Object.entries(categoryCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);

const AGENT_LABELS: Record<string, string> = {
  'claude-code': 'Claude Code',
  cursor: 'Cursor',
  windsurf: 'Windsurf',
  'codex-cli': 'Codex CLI',
  'gemini-cli': 'Gemini CLI',
  generic: 'Generic',
};
const agentIds = ['claude-code', 'cursor', 'windsurf', 'codex-cli', 'gemini-cli', 'generic'];
const agentCounts = agentIds.map(
  (id) =>
    [AGENT_LABELS[id] ?? id, entries.filter((e) => e.compat?.includes(id)).length] as [
      string,
      number,
    ],
);
const byAgent = agentCounts.filter(([, count]) => count > 0).sort((a, b) => b[1] - a[1]);
---

<Base title="Stats — SkillPulse">
  <div class="max-w-5xl mx-auto px-6 py-12">
    <h1 class="font-display font-extrabold text-4xl mb-2">Ecosystem Stats</h1>
    <p class="text-muted mb-10">
      {snapshot.totalEntries} entries · {new Date(snapshot.generatedAt).toLocaleString()}
    </p>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
      {
        (
          [
            ['Total', snapshot.totalEntries],
            ['Rising', entries.filter((e) => e.trend === 'rising').length],
            ['New', entries.filter((e) => e.trend === 'new').length],
            ['Categories', new Set(entries.map((e) => e.category)).size],
          ] as [string, number][]
        ).map(([label, value]) => (
          <div class="bg-surface border border-border rounded-lg p-5 text-center">
            <div class="font-display font-extrabold text-3xl text-accent mb-1">{value}</div>
            <div class="text-muted text-sm">{label}</div>
          </div>
        ))
      }
    </div>
    <section class="mb-10">
      <h2 class="font-display font-bold text-xl mb-4">By Kind</h2>
      <div class="space-y-2">
        {
          byKind.map(([kind, count]) => (
            <div class="flex items-center gap-3">
              <span class="text-muted text-sm w-32 shrink-0">{kind.replace(/-/g, ' ')}</span>
              <div class="flex-1 bg-border rounded-full h-2">
                <div
                  class="bg-accent h-2 rounded-full"
                  style={`width:${Math.round((count / entries.length) * 100)}%`}
                />
              </div>
              <span class="text-muted text-sm w-10 text-right">{count}</span>
            </div>
          ))
        }
      </div>
    </section>
    <section class="mb-10">
      <h2 class="font-display font-bold text-xl mb-4">By Agent</h2>
      {
        byAgent.length === 0 ? (
          <p class="text-muted text-sm">No agent compatibility data yet.</p>
        ) : (
          <div class="space-y-2">
            {byAgent.map(([label, count]) => (
              <div class="flex items-center gap-3">
                <span class="text-muted text-sm w-32 shrink-0">{label}</span>
                <div class="flex-1 bg-border rounded-full h-2">
                  <div
                    class="bg-accent h-2 rounded-full"
                    style={`width:${entries.length > 0 ? Math.round((count / entries.length) * 100) : 0}%`}
                  />
                </div>
                <span class="text-muted text-sm w-10 text-right">{count}</span>
              </div>
            ))}
          </div>
        )
      }
    </section>
    <section>
      <h2 class="font-display font-bold text-xl mb-4">Top Categories</h2>
      <div class="space-y-2">
        {
          byCategory.map(([cat, count]) => (
            <div class="flex items-center gap-3">
              <span class="text-muted text-sm w-40 shrink-0">{cat.replace(/-/g, ' ')}</span>
              <div class="flex-1 bg-border rounded-full h-2">
                <div
                  class="bg-gold h-2 rounded-full"
                  style={`width:${Math.round((count / entries.length) * 100)}%`}
                />
              </div>
              <span class="text-muted text-sm w-10 text-right">{count}</span>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</Base>
