---
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'The living registry of AI agent skills, MCPs, and prompts. Refreshed every 6h.',
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={`${title} | SkillPulse`} />
    <meta property="og:description" content={description} />
    <title>{title} | SkillPulse</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-bg text-text font-sans min-h-screen">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-accent text-bg px-4 py-2 rounded z-50"
      >Skip to content</a
    >
    <header class="border-b border-border py-4 px-6">
      <nav class="max-w-7xl mx-auto flex items-center justify-between" aria-label="Main">
        <a href="/skillpulse/" class="font-display font-extrabold text-xl flex items-center gap-2">
          <span class="inline-block w-3 h-3 bg-accent rounded-sm" aria-hidden="true"></span>
          SkillPulse
        </a>
        <ul class="flex gap-6 text-sm text-muted" role="list">
          <li><a href="/skillpulse/all" class="hover:text-text transition-colors">All Skills</a></li>
          <li><a href="/skillpulse/about" class="hover:text-text transition-colors">About</a></li>
          <li><a href="/skillpulse/stats" class="hover:text-text transition-colors">Stats</a></li>
          <li>
            <a
              href="https://github.com/corazzione/skillpulse/issues/new?template=submit-skill.yml"
              class="bg-accent text-bg px-3 py-1.5 rounded font-semibold hover:opacity-90 transition-opacity"
            >
              Submit
            </a>
          </li>
        </ul>
      </nav>
    </header>
    <main id="main"><slot /></main>
    <footer class="border-t border-border py-8 px-6 mt-16">
      <div class="max-w-7xl mx-auto flex items-center justify-between text-muted text-sm">
        <div class="flex items-center gap-2">
          <span class="inline-block w-2.5 h-2.5 bg-accent rounded-sm" aria-hidden="true"></span>
          <span class="font-display font-extrabold text-text">MC.</span>
          <span>· Open source</span>
        </div>
        <a href="https://github.com/corazzione/skillpulse" class="hover:text-text transition-colors"
          >GitHub</a
        >
      </div>
    </footer>
  </body>
</html>
